{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "allowJs": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@umrabor/ui": ["../../packages/ui/src/index.ts"],
      "@umrabor/ui/*": ["../../packages/ui/src/*"],
      "@umrabor/shared": ["../../packages/shared/src/index.ts"],
      "@umrabor/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
